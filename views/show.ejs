<% layout("/layouts/boilerplate") %>

    <div class="row row-cols-lg-1 row-cols-md-1 row-cols-sm-1 row-cols-1 align-items-start offset-lg-2">
        <div class="card edit-image col-lg-8 mb-3">
            <div id="carouselExample" class="carousel slide">
                <div class="carousel-inner">
                    <% for(let i=0; i< listingId.photos.length; i++) { %>
                        <% if(i===0) {%>
                            <div class="carousel-item active">
                                <img src="<%= listingId.photos[i] %>" class="d-block w-100" alt="Some image">
                            </div>
                            <% }else{ %>
                                <div class="carousel-item">
                                    <img src="<%= listingId.photos[i] %>" class="d-block w-100" alt="Some image">
                                </div>
                                <% } %>
                                    <% } %>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                    data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                    data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>

        <div class="col">
            <h1>
                <%= listingId.name %>
            </h1>
        </div>
        <div class="col">
            <p>
                <%= listingId.owner.username %>
            </p>
            <p>
                <%= listingId.description %>
            </p>
        </div>
        <div class="col">
            <p>$<%= listingId.price %>/night</p>
        </div>
        <div class="col">
            <p>
                <%= listingId.country %>
            </p>
        </div>
        <% if(currUser && currUser.equals(listingId.owner._id)) { %>
            <div class="col mb-3 d-flex gap-2">
                <button class="btn btn-primary"><a style="text-decoration: none; color: white;"
                        href="/listings/<%= listingId._id %>/edit">Edit</a></button>

                <form action="/listings/<%= listingId._id %>/delete?_method=DELETE" method="post" class="ml-2">
                    <button class="btn btn-primary">Delete</button>
                </form>
            </div>
            <% } %>

    </div>

    <hr>
    <h3>Leave a review</h3>
    <form action="/listings/<%= id %>/review/new" method="post" class="mb-3 needs-validation" novalidate>
        <div class="row row-cols-lg-2 row-cols-md-1 row-cols-sm-1 row-cols-1">
            <div class="col-lg-12">
                <label class="form-label" for="rating">Rate Stars</label>
                <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked
                        aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="rating" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="rating" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="rating" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="rating" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="rating" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-12">
                <label for="comment" class="form-label">Comment</label>
                <textarea style="width: 100%; height: 15rem;" name="comment" class="form-control" id="comment"
                    required></textarea>
                <div class="invalid-feedback">
                    Please enter a comment.
                </div>
            </div>
            <div class="col-lg-4 my-3">
                <button class="btn btn-secondary" type="submit">Submit</button>
            </div>
        </div>
    </form>

    <hr>

    <h3>Reviews</h3>
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 row-cols-1 mb-3">
        <% for(let review of reviews) {%>
            <div class="col-lg-4 col-md-5 col-sm-12 mb-2">
                <div class="card review-card ms-2 p-3" style="width: 18rem;">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= review.name %>
                        </h5>
                        <p class="card-text">
                            <%= review.comment %>
                        </p>
                        <p class="starability-result" data-rating="<%= review.rating %>">
                        </p>
                        <% if(currUser && currUser.equals(review.createdBy)) { %>
                            <form class="mb-2" action="/listings/<%= id %>/review/<%= review._id %>?_method=DELETE"
                                method="post">
                                <button type="submit" class="btn btn-dark">Delete</button>
                            </form>
                            <% } %>
                    </div>
                </div>
            </div>
            <% } %>
    </div>


    <div class="col-lg-8 my-4">
        <h3>Where you'll be</h3>
        <div id="map" style="height: 400px; border-radius: 10px; overflow: hidden;"></div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const coordinates = JSON.parse("<%- JSON.stringify(listingId.geoLocation.coordinates) %>");
            console.log('Coordinates:', coordinates); // Debug log

            if (!coordinates || coordinates.length !== 2) {
                console.error('Invalid coordinates format');
                return;
            }

            const map = new maplibregl.Map({
                container: "map",
                style:  "https://api.maptiler.com/maps/streets-v2/style.json?key=OaTtsssEI0ONU7qIGiFs",
                center: coordinates,
                zoom: 10
            });

            map.addControl(new maplibregl.NavigationControl());

            map.on('load', function () {
                new maplibregl.Marker()
                    .setLngLat(coordinates)
                    .addTo(map);
            });
        });
    </script>