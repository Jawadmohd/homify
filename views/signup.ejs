<% layout("/layouts/boilerplate") %>

<div class="row row d-flex vh-100 justify-content-center align-items-center">
    <div class="col-6">
        <h1>Signup</h1>
        <form action="/signup" method="post" class="needs-validation" novalidate>
        <div>
        <label class="form-label" for="username">Enter Username</label>
        <input id="username" class="form-control" type="text" name="username" required>
        </div>
        <div>
        <label class="form-label" for="email">Enter Email</label>
        <input id="email" class="form-control" type="email" name="email" required>
        </div>
        <div>
        <label class="form-label" for="password">Enter Password</label>
        <input id="password" class="form-control" type="password" name="password" required>
        </div>
        <button class="btn btn-success my-3" type="submit">Signup</button>
        </form>
    </div>
</div>